<Window x:Class="The_Dungeon_Bible.Views.RaceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Dungeon_Bible.Views"
        mc:Ignorable="d"
             Title="Login" Height="700" Width="450" Background="#FFDFDBC8">

    <Viewbox Stretch="Uniform">
        <Grid Width="450" Height="700">

            <Grid.Background>
                <ImageBrush ImageSource="..\Images\Parchment.png"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="450" Height="210">
                <Grid.Background>
                    <ImageBrush ImageSource="..\Images\RaceViewPicture.jpg"
                 Stretch="UniformToFill"/>
                </Grid.Background>
            </Grid>

            <Button Margin="0,0,371,180" Background="Bisque" FontFamily="Cambria" Content="Back" Command="{Binding BackButton}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="1"  ItemsSource="{Binding Races}" Margin="19,53,19,233" AutoGenerateColumns="True"  CanUserAddRows="True" Background="Beige" SelectedItem="{Binding SelectedRace}"/>

                <TextBlock Text="Races" HorizontalAlignment="Center" Margin="0,21,0,-21" FontFamily="Cambria" FontSize="18" Grid.Column="1"/>

                <TextBlock Text="Race Name" HorizontalAlignment="Left" Margin="35,21,0,-21" FontFamily="Cambria" FontSize="18"/>

                <TextBlock Text="Racial Feature" HorizontalAlignment="Center" Margin="0,90,0,-90" FontFamily="Cambria" FontSize="18"/>

                <TextBlock Text="Description" HorizontalAlignment="Center" Margin="0,249,0,-249" FontFamily="Cambria" FontSize="18"/>

          

                <TextBox Margin="4,53,4,405" Text="{Binding newrace.RaceName}" />
                <TextBox Margin="4,123,4,246" Text="{Binding newrace.RacialFeature}" />
                <TextBox Margin="4,278,4,78" Text="{Binding newrace.RacialLore}" />
               
                <Border Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="1" Background="Black" Margin="0.5"/>
                
                <Button Margin="20,266,225,200" Content="Save" Grid.Column="1" Background="Beige" Command="{Binding SaveRace}"/>
                <Button Margin="90,266,162,200" Content="Update" Grid.Column="1" Background="Beige" Command="{Binding UpdateRace}"/>
                <Button Margin="156,266,89,200" Content="Delete" Grid.Column="1" Background="Beige" Command="{Binding DeleteRace}"/>
                <Button Margin="227,266,20,200" Content="Clear" Grid.Column="1" Background="Beige" Command="{Binding ClearEntries}"/>

                <Image Source="/Images/MushroomRun.png" Margin="38,135,112,-135" Grid.Column="1"/>
                <Image Source="/Images/MushroomRun.png" Margin="170,196,36,-90" Grid.Column="1"/>
                <Image Source="/Images/MushroomRun.png" Margin="124,236,83,-130" Grid.Column="1"/>
            </Grid>

        </Grid>
    </Viewbox>
</Window>