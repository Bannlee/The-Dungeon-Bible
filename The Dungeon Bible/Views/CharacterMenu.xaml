<Window x:Class="The_Dungeon_Bible.Views.CharacterMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Dungeon_Bible.Views"
        mc:Ignorable="d"
        Title="Login" Height="700" Width="450" Background="#FFDFDBC8">

    <Viewbox Stretch="Uniform">
        <Grid Width="450" Height="700">

            <Grid.Background>
                <ImageBrush ImageSource="..\Images\Parchment.png"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="450" Height="210">
                <Grid.Background>
                    <ImageBrush ImageSource="..\Images\MarcilleFalin.jpg"
                 Stretch="UniformToFill"/>
                </Grid.Background>
            </Grid>

            <TextBlock
             Text="My Characters"
             Grid.Row="1"
             HorizontalAlignment="Center"
             VerticalAlignment="Top"
             FontSize="36"
             FontFamily="Palatino Linotype"
             FontWeight="Bold" Margin="0,10,0,0"
             Foreground="DarkRed"/>

            <!--THIS IS FOR CHARACTER 1-->
            <Rectangle  Grid.Row="1" Fill="Beige" Stroke="IndianRed" Margin="25,75,24,303" StrokeThickness="3"/>


                <Image Source="..\Images\CharacterIcon.jpg" Margin="3,82,289,311" Grid.Row="1" />

            <StackPanel Grid.Row="1">
                <TextBlock Grid.Row="1" Text="{Binding Characterlist[0].Charname}" Margin="135,85,0,-85" FontSize="22"
              FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left"/>
            <TextBlock Grid.Row="1" Text="{Binding Char1Race.RaceName}" Margin="135,85,0,-112" FontSize="15"
             FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>
                
                <TextBlock Grid.Row="1" Text="{Binding Char1Class.ClassName}" Margin="210,85,0,-112" FontSize="15"
              FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>
            </StackPanel>
            <Button Grid.Row="1" Margin="319,85,44,369" FontFamily="Cambria" Content="Edit" Background="Bisque" BorderBrush="DarkRed" />
            <Button Grid.Row="1" Margin="319,140,44,315" FontFamily="Cambria" Content="View" Background="Bisque" BorderBrush="DarkRed" />
            
            <!--THIS IS FOR CHARACTER 1-->
            
            
            <!--THIS IS FOR CHARACTER 2-->
            <Rectangle  Grid.Row="1" Fill="Beige" Stroke="IndianRed" Margin="24,215,24,163" StrokeThickness="3" />


                <Image Source="..\Images\CharacterIcon.jpg" Margin="3,222,289,170" Grid.Row="1" />
                
            <StackPanel Grid.Row="1" Margin="0, 140">
                <TextBlock Grid.Row="1" Text="{Binding Characterlist[1].Charname}" Margin="135,85,0,-85" FontSize="22"
                FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Text="{Binding Char2Race.RaceName}" Margin="135,85,0,-112" FontSize="15"
                FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>
                <TextBlock Grid.Row="1" Text="{Binding Char2Class.ClassName}" Margin="210,85,0,-112" FontSize="15"
                 FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>
            </StackPanel>
            <Button Grid.Row="1" Margin="319,228,44,228" FontFamily="Cambria" Content="Edit" Background="Bisque" BorderBrush="DarkRed" />
            <Button Grid.Row="1" Margin="319,282,44,173" FontFamily="Cambria" Content="View" Background="Bisque" BorderBrush="DarkRed" />
            <!--THIS IS FOR CHARACTER 2-->

            <!--THIS IS FOR CHARACTER 3-->
            <Rectangle  Grid.Row="1" Fill="Beige" Stroke="IndianRed" Margin="25,351,24,27" StrokeThickness="3"/>

                <Image Source="..\Images\CharacterIcon.jpg" Margin="2,360,290,33" Grid.Row="1" />


            <TextBlock Grid.Row="1" Text="{Binding Characterlist[1].Charname}" Margin="135,364,0,-364" FontSize="22"
            FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Text="{Binding Char3Race.RaceName}" Margin="135,396,0,-423" FontSize="15"
            FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>
                <TextBlock Grid.Row="1" Text="{Binding Char3Class.ClassName}" Margin="210,396,0,-423" FontSize="15"
            FontFamily="Cambria" FontWeight="Bold" HorizontalAlignment="Left" Foreground="DarkRed"/>

            <Button Grid.Row="1" Margin="319,364,44,92" FontFamily="Cambria" Content="Edit" Background="Bisque" BorderBrush="DarkRed" />
            <Button Grid.Row="1" Margin="319,417,44,38" FontFamily="Cambria" Content="View" Background="Bisque" BorderBrush="DarkRed" />
            <!--THIS IS FOR CHARACTER 3-->
            

        </Grid>
    </Viewbox>
</Window>
