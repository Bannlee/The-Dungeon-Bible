<Window x:Class="The_Dungeon_Bible.Views.CharacterMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Dungeon_Bible.Views"
        mc:Ignorable="d"
        Title="Login" Height="700" Width="450" Background="#FFDFDBC8">

    <Viewbox Stretch="Uniform">
        <Grid Width="450" Height="700">

            <Grid.Background>
                <ImageBrush ImageSource="..\Images\Parchment.png"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="450" Height="210">
                <Grid.Background>
                    <ImageBrush ImageSource="..\Images\MarcilleFalin.jpg"
                 Stretch="UniformToFill"/>
                </Grid.Background>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <DataGrid                              
        Grid.Column="1" 
        Margin="19,53,19,233" 
        AutoGenerateColumns="True" 
        ItemsSource="{Binding Characterlist}" 
        CanUserAddRows="True" 
                    Background="Beige"/>

                <TextBlock Text="My Characters" HorizontalAlignment="Center" Margin="0,21,0,-21" FontFamily="Cambria" FontSize="18" Grid.Column="1"/>

                <TextBlock Text="Name" HorizontalAlignment="Left" Margin="55,21,0,-21" FontFamily="Cambria" FontSize="18"/>

                <TextBlock Text="Race" HorizontalAlignment="Center" Margin="0,90,0,-90" FontFamily="Cambria" FontSize="18"/>

                <TextBlock Text="Class" HorizontalAlignment="Center" Margin="0,160,0,-160" FontFamily="Cambria" FontSize="18"/>

                <TextBlock Text="Level" HorizontalAlignment="Left" Margin="57,229,0,-229" FontFamily="Cambria" FontSize="18"/>

                <TextBox Margin="4,53,4,405" Text="{Binding newcharacter.Charname}"/>
                <TextBox Margin="4,123,4,335" Text="{Binding newcharacter.Race}"/>
                <TextBox Margin="4,192,4,266" Text="{Binding newcharacter.Class}"/>
                <TextBox Margin="4,258,4,200" Text="{Binding newcharacter.Level}"/>
                <Border Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="1" Background="Black" Margin="0.5"/>
                <Button Margin="20,266,205,200" Content="Save" Grid.Column="1" Background="Beige" Command="{Binding SaveCharacter}"/>
                <Button Margin="112,266,112,200" Content="Delete" Grid.Column="1" Background="Beige"/>
                <Button Margin="205,266,20,200" Content="Clear" Grid.Column="1" Background="Beige" Command="{Binding ClearEntries}"/>

                <Image Source="/Images/MushroomRun.png" Margin="38,135,112,-135" Grid.Column="1"/>
                <Image Source="/Images/MushroomRun.png" Margin="170,196,36,-90" Grid.Column="1"/>
                <Image Source="/Images/MushroomRun.png" Margin="124,236,83,-130" Grid.Column="1"/>
            </Grid>

        </Grid>
    </Viewbox>
</Window>
