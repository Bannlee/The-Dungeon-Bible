<Window x:Class="The_Dungeon_Bible.Views.EditCharacterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Dungeon_Bible.Views"
        mc:Ignorable="d"
        Title="Login" Height="700" Width="450" Background="#FFDFDBC8">

    <Viewbox Stretch="Uniform">
        <Grid Width="450" Height="700">

            <Grid.Background>
                <ImageBrush ImageSource="..\Images\Parchment.png"/>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="450" Height="210">
                <Grid.Background>
                    <ImageBrush ImageSource="..\Images\EditCharacterPicture.jpg"
             Stretch="UniformToFill" />
                </Grid.Background>
            </Grid>

            <Button Margin="0,0,371,180" Background="Bisque" FontFamily="Cambria" Content="Back"
             Command ="{Binding Return}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

            <TextBlock Text="{Binding savemessage}" HorizontalAlignment="Left" Margin="97,57,0,223" FontFamily="Cambria" FontSize="20" Width="128" Grid.Row="1" Foreground="#5198ED"/>
            <!---BUttons and stuff-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="292"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="1" Background="Black" Margin="0.5"/>

                <TextBlock Text="Edit Character" HorizontalAlignment="Center" Margin="0,10,0,-10" FontFamily="Cambria" FontSize="20" Width="128"/>
                <TextBlock Text="Stats" HorizontalAlignment="Left" Margin="59,10,0,-10" FontFamily="Cambria" FontSize="20" Width="128" Grid.Column="1"/>

                <TextBlock Text="Name" HorizontalAlignment="Left" Margin="15,55,0,-56" FontFamily="Cambria" FontSize="18" Width="110"/>
                <TextBlock Text="Race" HorizontalAlignment="Left" Margin="15,131,0,-131" FontFamily="Cambria" FontSize="18" Width="110"/>
                <TextBlock Text="Class" HorizontalAlignment="Left" Margin="15,212,0,-212" FontFamily="Cambria" FontSize="18" Width="110"/>
                <TextBlock Text="Class" HorizontalAlignment="Left" Margin="15,212,0,-212" FontFamily="Cambria" FontSize="18" Width="110"/>
                <TextBlock Text="Level" HorizontalAlignment="Left" Margin="15,283,0,-283" FontFamily="Cambria" FontSize="18" Width="110"/>

                <TextBox Margin="15,86,15,366" Text="{Binding SelectedCharacter.Charname}"/>

                <ComboBox Margin="15,164,15,292" ItemsSource="{Binding Races}"
             SelectedItem="{Binding SelectedCharacter.Charrace}"
             DisplayMemberPath="RaceName"/>

                <ComboBox Margin="15,238,15,218"
                ItemsSource="{Binding Classes}"
                SelectedItem="{Binding SelectedCharacter.Charclass}"
                DisplayMemberPath="ClassName"/>

                <TextBox Margin="15,304,145,153" Text="{Binding SelectedCharacter.Level}"/>



                <!--STATS AREA-->

                <TextBlock Grid.Column="1" Text="Strength" FontFamily="Cambria" FontSize="18" Margin="0,58,0,-58" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="16,86,10,371" Text="{Binding Currentstats[0]}"/>


                <TextBlock Grid.Column="1" Text="Dexterity" FontFamily="Cambria" FontSize="18" Margin="0,119,0,-119" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="16,148,10,309" Text="{Binding Currentstats[1]}"/>


                <TextBlock Grid.Column="1" Text="Constitution" FontFamily="Cambria" FontSize="18" Margin="0,186,0,-186" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="16,212,10,245" Text="{Binding Currentstats[2]}"/>



                <TextBlock Grid.Column="1" Text="Intelligence" FontFamily="Cambria" FontSize="18" Margin="0,255,0,-255" HorizontalAlignment="Center"/>
                <TextBox Margin="13,287,13,170" Text="{Binding Currentstats[3]}" Grid.Column="1"/>


                <TextBlock Grid.Column="1" Text="Wisdom" FontFamily="Cambria" FontSize="18" Margin="0,322,0,-322" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="16,353,10,104" Text="{Binding Currentstats[4]}"/>


                <TextBlock Grid.Column="1" Text="Charisma" FontFamily="Cambria" FontSize="18" Margin="0,393,0,-393" HorizontalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="16,423,10,34" Text="{Binding Currentstats[5]}"/>


                <Button Margin="15,369,167,83" Background="Bisque" BorderBrush="DarkRed" FontFamily="Cambria" Content="Save" Command="{Binding SaveChar}"/>
                <Button Margin="167,370,15,82" Background="Bisque" BorderBrush="DarkRed" FontFamily="Cambria" Content="Clear" Command="{Binding ClearEntries}"/>







            </Grid>
        </Grid>
    </Viewbox>
</Window>
