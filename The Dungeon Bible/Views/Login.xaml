<Window x:Class="The_Dungeon_Bible.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Dungeon_Bible.Views"
        mc:Ignorable="d"
        Title="Login" Height="700" Width="450" Background="#FFDFDBC8">

    <Viewbox Stretch="Uniform">
        <Grid Width="450" Height="700">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFE2D1AB"/>
                    <GradientStop Color="#FFDDD2BA" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="210"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="450" Height="210">
                <Grid.Background>
                    <ImageBrush ImageSource="..\Images\DungeonMesh1.jpg"
                            Stretch="UniformToFill"/>
                </Grid.Background>
            </Grid>

            <Grid Grid.Row="1">
            <Grid.Background>
                <ImageBrush ImageSource="..\Images\Parchment.png"/>
            </Grid.Background>

                <Image Source="..\Images\MushroomRun.png"
                       
                  Margin="0, 260, 0, 0"/>
            </Grid>

            <TextBlock
              Text="The Dungeon Bible"
              Grid.Row="1"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              FontSize="36"
              FontFamily="Palatino Linotype"
              FontWeight="Bold" Margin="0,10,0,0"
              Foreground="DarkRed"/>

            <TextBlock
              Text="Login"
              Grid.Row="1"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              FontSize="30"
              FontFamily="Cambria" Margin="50,100,0,0"/>

            <TextBox Height="30" Width="350" Grid.Row="1" Margin="50,140,50,320" Text="{Binding CurrentUser.Username, UpdateSourceTrigger=PropertyChanged}"/>

            <PasswordBox x:Name = "Passbx" Height="30" Width="350" Grid.Row="1" Margin="50,198,50,262"/>

            <Button Grid.Row="1" Height="40" Width="300" Background="White" Content="Login" FontFamily="Cambria" FontSize="20" Margin="0,50,0, 0" Command="{Binding LoginCommand}"  CommandParameter="{Binding ElementName=Passbx}"/>




        </Grid>
    </Viewbox>
</Window>
